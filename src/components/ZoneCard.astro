---
interface Props {
  title: string;
  desc: string;
  href: string;
}
const { title, desc, href } = Astro.props;
---
<a href={href} class="product-card">
  <div class="product-card__body">
    <h3 class="product-card__title">{title}</h3>
    <p class="product-card__desc">{desc}</p>
    <span class="btn btn-sm btn-outline" style="margin-top:8px;">Ver cobertura →</span>
  </div>
</a>
