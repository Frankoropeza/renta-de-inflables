---
const phone = '5531281706';
const waLink = `https://wa.me/52${phone}?text=${encodeURIComponent('Hola, me interesa rentar un inflable para mi evento 🎉')}`;

const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Inflables', href: '/inflables/' },
  { label: 'Servicios', href: '/servicios/' },
  { label: 'Paquetes', href: '/paquetes/' },
  { label: 'Cobertura', href: '/cobertura/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contacto', href: '/contacto/' },
];
---
<header class="hdr" id="main-header">
  <div class="container hdr__inner">
    <a href="/" class="hdr__logo">
      <img src="/img/logo.png" alt="Inflafi – Renta de Inflables" width="160" height="48" />
    </a>

    <nav class="hdr__nav" id="main-nav">
      {navItems.map(item => (
        <a href={item.href} class="hdr__link">{item.label}</a>
      ))}
    </nav>

    <a href={waLink} target="_blank" rel="noopener" class="btn btn-sm btn-white hdr__cta">
      💬 Cotizar Ahora
    </a>

    <button class="hdr__burger" id="burger-btn" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu">
  <nav class="mobile-menu__nav">
    {navItems.map(item => (
      <a href={item.href} class="mobile-menu__link">{item.label}</a>
    ))}
    <a href={waLink} target="_blank" rel="noopener" class="btn btn-wa btn-lg mobile-menu__cta">
      💬 Cotizar por WhatsApp
    </a>
  </nav>
</div>

<style>
  .hdr {
    background: #ff12cc;
    height: var(--header-height);
    position: fixed;
    top: var(--topbar-height);
    left: 0; right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }
  .hdr__logo img { height: 44px; width: auto; }
  .hdr__nav { display: flex; gap: 28px; }
  .hdr__link {
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: .95rem;
    transition: opacity .2s;
  }
  .hdr__link:hover { opacity: .8; }
  .hdr__cta { white-space: nowrap; }
  .hdr__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hdr__burger span {
    display: block;
    width: 26px;
    height: 3px;
    background: #fff;
    border-radius: 2px;
    transition: .3s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: calc(var(--topbar-height) + var(--header-height));
    left: 0; right: 0; bottom: 0;
    background: var(--color-secondary);
    z-index: 999;
    overflow-y: auto;
    padding: 32px 24px;
  }
  .mobile-menu.open { display: block; }
  .mobile-menu__nav { display: flex; flex-direction: column; gap: 20px; }
  .mobile-menu__link {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }
  .mobile-menu__cta { margin-top: 16px; text-align: center; justify-content: center; }

  @media (max-width: 1024px) {
    .hdr__nav, .hdr__cta { display: none; }
    .hdr__burger { display: flex; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var burger = document.getElementById('burger-btn');
    var menu = document.getElementById('mobile-menu');
    if (!burger || !menu) return;

    burger.addEventListener('click', function() {
      var isOpen = menu.classList.toggle('open');
      burger.setAttribute('aria-expanded', isOpen);
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    // Cerrar al tocar un enlace
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  });
</script>
